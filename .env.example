# Panel login. Change these before exposing the panel.
PANEL_USERNAME=admin
PANEL_PASSWORD=change-me

# Use long random values in production.
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key

# Qinglong container image settings.
QL_IMAGE=whyour/qinglong:latest
QL0_IMAGE=whyour/qinglong:debian-python3.10

# Container-side path used by the panel when creating Qinglong data folders.
QL_DATA_PATH=/home/docker/qinglong

# Host-side persistent paths.
QL_HOST_DATA_PATH=/home/docker/qinglong
PANEL_HOST_DATA_PATH=./data
NGINX_HOST_PATH=/home/docker/nginx
